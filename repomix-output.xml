          </div>

          {/* Customer Information Section */}
          <div className="bg-[#004B93]/5 rounded-xl p-3 space-y-3">
            <p className="text-xs font-semibold text-[#004B93] uppercase tracking-wide">Customer Information</p>

            <div>
