              <input
                type="checkbox"
                checked={checked[i]}
                onChange={() => toggle(i)}
                className="w-5 h-5 accent-[#004B93]"
              />
              <span className={`text-sm ${checked[i] ? 'line-through text-gray-400' : 'text-gray-700'}`}>
                {item}
              </span>
            </label>
