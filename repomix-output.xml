        </div>

        {profile?.role === 'manager' && (
          <div className="bg-white rounded-xl border border-gray-200 p-6">
            <p className="text-sm font-semibold text-gray-700 mb-3">Team Management</p>
            <button
              onClick={() => setShowCreateEmployee(true)}
