            onClick={() => { setSelectedEvent(null); setDefaultDate(new Date().toISOString().slice(0, 16)); setShowModal(true) }}
            className="bg-[#004B93] text-white px-3 py-1 rounded-lg text-sm hover:bg-[#003d7a] transition"
          >
            + Event
