# Copy to .env.local for local development (never commit .env.local)

# --- Client (Vite) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_ENABLE_PLATFORM_FEATURES=true
# vercel dev default; use http://localhost:5173 for vite-only (npm run dev)
VITE_PLATFORM_URL=http://localhost:3001

# --- Server (required for npm run dev:full / API routes) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ENABLE_PLATFORM_FEATURES=true

# Contact follow-up cron — local manual test:
# curl -H "Authorization: Bearer local-dev-cron-secret" http://localhost:3001/api/cron/contact-follow-up
CRON_SECRET=local-dev-cron-secret-change-me

# --- Optional: maps, SMS, push (match your Vercel preview/dev env) ---
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# SMS alert when inbound cannot be routed to any org (unrouted_inbound capture)
PLATFORM_ALERT_PHONE=
# Employee alerts via WhatsApp — number only (e.g. +15559367913). Do not typo "whatsapp".
TWILIO_WHATSAPP_FROM=
# Approved Content Template SIDs (HX...) — variables {{1}}, {{2}}, … must match employeeWhatsAppTemplates.ts
# Or use a static assignment template (no {{variables}}) and set TWILIO_WHATSAPP_ASSIGNMENT_STATIC=true
TWILIO_WHATSAPP_ASSIGNMENT_STATIC=
# Number of {{n}} placeholders in assignment template (default 4). Use 3 to omit URL variable.
TWILIO_WHATSAPP_ASSIGNMENT_VAR_COUNT=
TWILIO_WHATSAPP_CONTENT_SID_ASSIGNMENT=
# Manager alert: {{1}} lead name, {{2}} URL — template body includes brand name (e.g. FieldBourne Digital)
TWILIO_WHATSAPP_CONTENT_SID_MANAGER_ALERT=
TWILIO_WHATSAPP_CONTENT_SID_FOLLOW_UP=
TWILIO_WHATSAPP_CONTENT_SID_NOTIFY=
TWILIO_WHATSAPP_CONTENT_SID_BOOKING=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# --- Optional: AI / integrations ---
# VITE_CLAUDE_MODEL=claude-sonnet-4-6
# VITE_ANTHROPIC_API_KEY=
# VITE_VAPID_PUBLIC_KEY=
# --- Inbound webhooks (required for simulator + CloudMailin/Twilio) ---
INBOUND_SECRET=local-dev-inbound-secret-change-me
VITE_CLOUDMAILIN_INBOUND_BASE=your-inbound@cloudmailin.net
# TWILIO_AUTH_TOKEN=  # required for SMS simulator only
# THREECX_WEBHOOK_SECRET=
# STITCH_API_KEY=

# Stripe (test mode)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# Meta Messenger + Instagram DM webhook (same /api/meta-webhook endpoint)
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=
# META_PAGE_ACCESS_TOKEN=
