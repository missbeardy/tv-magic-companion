# Copy to .env.local for local development (never commit .env.local)

VITE_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_dev_anon_key

VITE_ENABLE_PLATFORM_FEATURES=true
# Optional locally only — Vercel auto-detects via VERCEL_URL / VERCEL_BRANCH_URL
# VITE_PLATFORM_URL=http://localhost:5173

# Server-side (Vercel / vercel dev) — same Supabase project as above
SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ENABLE_PLATFORM_FEATURES=true

# Stripe (test mode for preview/dev until production cutover)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Optional
# VITE_CLAUDE_MODEL=claude-sonnet-4-6
# VITE_VAPID_PUBLIC_KEY=
