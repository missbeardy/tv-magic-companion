{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "vite --port $PORT --strictPort",
  "framework": "vite",
  "outputDirectory": "dist",
  "functions": {
    "api/send-sms.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/cron/contact-follow-up",
      "destination": "/api/send-sms?action=contact-follow-up"
    },
    {
      "source": "/api/meta-webhook",
      "destination": "/api/inbound-sms?action=meta-webhook"
    },
    {
      "source": "/api/send-notification",
      "destination": "/api/send-sms?action=notify"
    },
    {
      "source": "/api/stripe-checkout",
      "destination": "/api/stripe?action=checkout"
    },
    {
      "source": "/api/stripe-portal",
      "destination": "/api/stripe?action=portal"
    },
    {
      "source": "/api/stripe-webhook",
      "destination": "/api/stripe?action=webhook"
    },
    {
      "source": "/api/places-autocomplete",
      "destination": "/api/geocode?action=autocomplete"
    },
    {
      "source": "/api/platform-simulate-inbound",
      "destination": "/api/create-user?action=simulate-inbound"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}