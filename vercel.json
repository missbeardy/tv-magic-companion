{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "vite --port $PORT --strictPort",
  "framework": "vite",
  "outputDirectory": "dist",
  "functions": {
    "api/send-sms.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=(self), interest-cohort=()"
        },
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; script-src 'self' https://cdn.onesignal.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.onesignal.com; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; worker-src 'self'; frame-src 'self' https://*.onesignal.com; manifest-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron/contact-follow-up",
      "destination": "/api/send-sms?action=contact-follow-up"
    },
    {
      "source": "/api/meta-webhook",
      "destination": "/api/inbound-sms?action=meta-webhook"
    },
    {
      "source": "/api/send-notification",
      "destination": "/api/send-sms?action=notify"
    },
    {
      "source": "/api/stripe-checkout",
      "destination": "/api/stripe?action=checkout"
    },
    {
      "source": "/api/stripe-portal",
      "destination": "/api/stripe?action=portal"
    },
    {
      "source": "/api/stripe-webhook",
      "destination": "/api/stripe?action=webhook"
    },
    {
      "source": "/api/places-autocomplete",
      "destination": "/api/geocode?action=autocomplete"
    },
    {
      "source": "/api/platform-simulate-inbound",
      "destination": "/api/create-user?action=simulate-inbound"
    },
    {
      "source": "/api/inbound-facebook-lead",
      "destination": "/api/inbound-email?action=facebook-lead"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}